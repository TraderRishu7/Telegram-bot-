def get_timezone_from_offset(offset_str):
    sign = -1 if "-" in offset_str else 1
    hours, minutes = map(int, offset_str.replace("+", "").replace("-", "").split(":"))
    return timezone(timedelta(hours=sign * hours, minutes=sign * minutes))

# --- Trader ID Verification ---
async def verify_trader_id(trader_id):
    try:
        url = "https://raw.githubusercontent.com/TraderRishu7/credentials-Rishu/main/key.json"
        async with httpx.AsyncClient() as client:
            response = await client.get(url)
            data = response.json()

        if trader_id in data.get("live_keys", []):
            return "live"
        if trader_id in data.get("future_keys", []):
            return "future"
        if trader_id in data.get("master_keys", []):
            return "master"
    except Exception as e:
        logging.error(f"Error verifying trader ID: {e}")
    return None

