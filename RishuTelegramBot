async def next_signal(update: Update, context: ContextTypes.DEFAULT_TYPE):
    if not context.user_data.get("live_mode_active", False):
        await update.message.reply_text("❌ You are not in Live Mode. Use /start to begin again.")
        return ConversationHandler.END

    # Prevent new signal until current one completes
    if context.user_data.get("signal_running", False):
        await update.message.reply_text("⚠️ Please wait for the current trade to complete before generating the next signal.")
        return ConversationHandler.END

    await send_single_live_signal(context, update.message.chat_id)
    return ConversationHandler.END


