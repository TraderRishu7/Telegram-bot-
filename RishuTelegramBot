async def select_asset(update: Update, context: ContextTypes.DEFAULT_TYPE):
    input_text = update.message.text.strip().upper()

    # Split user input
    entered_assets = [a.strip().upper() for a in input_text.split(",") if a.strip()]

    valid_assets = []
    invalid_assets = []

    for a in entered_assets:
        if a in OTC_ASSETS:
            valid_assets.append(a)
        else:
            invalid_assets.append(a)

    if not valid_assets:
        await update.message.reply_text(
            "❌ No valid assets found.\n\n"
            "Please enter assets like:\n`USDBDT-OTC, USDINR-OTC`",
            parse_mode="Markdown"
        )
        return ASSET_SELECTION

    # If some assets were invalid → show a warning
    if invalid_assets:
        await update.message.reply_text(
            "⚠️ Some assets were ignored:\n" +
            "\n".join([f"• `{a}`" for a in invalid_assets]) +
            "\n\n✔ Using only valid assets.",
            parse_mode="Markdown"
        )

    context.user_data["selected_assets"] = valid_assets

    asset_list = "\n".join([f"• `{a}`" for a in valid_assets])
    await update.message.reply_text(
        f"✅ Selected assets:\n\n{asset_list}\n\n"
        "💬 How many total signals do you want to generate?",
        parse_mode="Markdown"
    )
    return NUMBER_OF_SIGNALS

async def ask_signal_count(update: Update, context: ContextTypes.DEFAULT_TYPE):
    count_text = update.message.text.strip()
    if not count_text.isdigit() or int(count_text) <= 0:
        await update.message.reply_text("❌ Please enter a valid number greater than 0.")
        return NUMBER_OF_SIGNALS

    context.user_data["signal_count"] = int(count_text)
    await update.message.reply_text(
        f"✅ Generating *{count_text}* signals.\n\nType `yes` to confirm or `no` to cancel:",
        parse_mode="Markdown"
    )
    return CONFIRM_GENERATE

async def confirm_generation(update: Update, context: ContextTypes.DEFAULT_TYPE):
    response = update.message.text.strip().lower()
    if response == "yes":
        assets = context.user_data.get("selected_assets")
        count = context.user_data.get("signal_count")
        await update.message.reply_text("✅ Signals confirmed. Generating...")
        asyncio.create_task(send_future_signals_list(context, update.message.chat_id, assets, count))
        return ConversationHandler.END
    elif response == "no":
        await update.message.reply_text("❌ Signal generation cancelled. Use /start to begin again.")
        return ConversationHandler.END
    else:
        await update.message.reply_text("Please type `yes` or `no`.")
        return CONFIRM_GENERATE

async def send_future_signals_list(context, chat_id, assets, count):
    tz = get_timezone_from_offset(context.user_data["timezone_offset"])
    now = datetime.now(tz).replace(second=0, microsecond=0)
    base_time = now
    signals = []
    last_direction = None
    same_count = 0

    for _ in range(count):
        base_time += timedelta(minutes=random.randint(4, 15))
        time_str = base_time.strftime("%H:%M")
        direction = random.choice(DIRECTIONS)

        if direction == last_direction:
            same_count += 1
        else:
            same_count = 0
        if same_count >= 3:
            direction = "CALL" if direction == "PUT" else "PUT"
            same_count = 0

        last_direction = direction
        asset = random.choice(assets)
        signals.append(f"`M1 {asset} {time_str} {direction}`")

    await context.bot.send_message(chat_id=chat_id, text="\n".join(signals), parse_mode="Markdown")

# --- Cancel Command ---
async def cancel(update: Update, context: ContextTypes.DEFAULT_TYPE):
    context.user_data["live_mode_active"] = False

    # Cancel any running tasks cleanly
    for key in ["live_signal_task", "trade_complete_task"]:
        task = context.user_data.get(key)
        if task and not task.done():
            task.cancel()
            try:
                await task
            except asyncio.CancelledError:
                logging.info(f"Cancelled task: {key}")

    await update.message.reply_text("❌ All processes stopped. You can use /start to restart.")
    return ConversationHandler.END


# --- Main Function ---
def main():
    import os
    from telegram.error import NetworkError

    # Remove proxy vars
    os.environ.pop("HTTP_PROXY", None)
    os.environ.pop("HTTPS_PROXY", None)

    # Create bot app
    app = ApplicationBuilder().token(BOT_TOKEN).build()

    # Error handler
    async def error_handler(update, context):
        try:
            raise context.error
        except NetworkError as e:
            logging.warning(f"[⚠️ NetworkError] {e}")
        except Exception as e:
            logging.error(f"[❌ Unexpected Error] {e}", exc_info=True)

    app.add_error_handler(error_handler)

    # Conversation handler
    conv_handler = ConversationHandler(
        entry_points=[CommandHandler("start", start)],
        states={
            TRADER_ID: [MessageHandler(filters.TEXT & ~filters.COMMAND, ask_trader_id)],
            SELECT_TYPE: [CallbackQueryHandler(handle_signal_type)],
            ASK_TIMEZONE: [MessageHandler(filters.TEXT & ~filters.COMMAND, handle_timezone_input)],
            ASSET_SELECTION: [MessageHandler(filters.TEXT & ~filters.COMMAND, select_asset)],
            NUMBER_OF_SIGNALS: [MessageHandler(filters.TEXT & ~filters.COMMAND, ask_signal_count)],
            CONFIRM_GENERATE: [MessageHandler(filters.TEXT & ~filters.COMMAND, confirm_generation)],
            LIVE_CONFIRM: [CallbackQueryHandler(handle_live_actions)],
        },
        fallbacks=[CommandHandler("cancel", cancel)]
    )

    app.add_handler(conv_handler)
    app.add_handler(CommandHandler("nextsignal", next_signal))
    app.add_handler(CommandHandler("cancel", cancel))

    logging.info("🚀 Bot is now running and ready to serve signals...")

keep_alive()
   
   # Run bot forever
while True:
    try:
        logging.info("🚀 Bot started...")
        app.run_polling(drop_pending_updates=True)

    except Exception as e:
        logging.error(f"Bot crashed: {e}")


if __name__ == "__main__":
    main()
