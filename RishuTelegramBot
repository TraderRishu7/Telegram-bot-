    now = datetime.now(tz)
    context.user_data["timeframe"] = "1"
    context.user_data["live_mode_active"] = True

    keyboard = InlineKeyboardMarkup([
        [InlineKeyboardButton("Generate Signals", callback_data="generate_live")],
        [InlineKeyboardButton("Cancel", callback_data="cancel_live")]
    ])

    await context.bot.send_message(
        update_or_query.effective_chat.id,
