async def handle_live_actions(update: Update, context: ContextTypes.DEFAULT_TYPE):
    query = update.callback_query
    await query.answer()
    chat_id = query.message.chat_id

    if query.data == "cancel_live":
        await query.message.edit_text("🚫 Live session ended. Use /start to restart.")
        context.user_data["live_mode_active"] = False
        context.user_data["signal_running"] = False
        return ConversationHandler.END

    if query.data in ("generate_live", "next_live_signal"):
        # Prevent if a trade is already active
        if context.user_data.get("signal_running", False):
            await query.message.reply_text("⚠️ Please wait until the current trade is completed before generating another signal.")
            return LIVE_CONFIRM

        if not context.user_data.get("live_mode_active", False):
            await query.message.reply_text("❌ You are not in Live Mode. Use /start to begin again.")
            return ConversationHandler.END

        # Disable the "Generate Signals" button while trade is active
        try:
            await query.message.edit_reply_markup(
                InlineKeyboardMarkup([
                    [InlineKeyboardButton("⏳ Waiting for trade...", callback_data="disabled")],
                    [InlineKeyboardButton("Cancel", callback_data="cancel_live")]
                ])
            )
        except Exception as e:
            logging.warning(f"Failed to disable button: {e}")

        await send_single_live_signal(context, chat_id)
        return LIVE_CONFIRM



async def send_single_live_signal(context, chat_id):
    # Prevent generating multiple signals at once
    if context.user_data.get("signal_running", False):
        await context.bot.send_message(chat_id=chat_id, text="⚠️ Please wait for the current trade to complete before generating the next signal.")
        return

    context.user_data["signal_running"] = True  # mark signal as active

    tz = get_timezone_from_offset(context.user_data["timezone_offset"])
    now = datetime.now(tz).replace(microsecond=0)

    # Align to next full minute entry
    entry_time = (now + timedelta(minutes=1)).replace(second=0)

    # If already past entry_time - 30s, shift to next minute
    if now >= entry_time - timedelta(seconds=30):
        entry_time = entry_time + timedelta(minutes=1)

    send_time = entry_time - timedelta(seconds=30)
    exit_time = entry_time + timedelta(minutes=1, seconds=5)

    wait_seconds = (send_time - now).total_seconds()
    if wait_seconds > 0:
        await asyncio.sleep(wait_seconds)

    asset = random.choice(OTC_ASSETS)
    direction = random.choice(DIRECTIONS)
    accuracy = random.randint(83, 98)

    msg = (
        "*👑 RISHU QUOTEX OTC 👑*\n\n"
        f"*📌 Asset:* {escape_md(asset)}\n"
        f"*⌛️ Entry Time:* {escape_md(entry_time.strftime('%H:%M:%S'))}\n"
        f"*⚔️ Direction:* {escape_md(direction)}\n"
        f"*⏰ Timeframe:* {escape_md('1 Minute')}\n"
        f"*🌟 Accuracy:* {escape_md(str(accuracy))}%\n\n"
        "*💲Follow Proper Money Management*"
    )

    await context.bot.send_message(chat_id=chat_id, text=msg, parse_mode=ParseMode.MARKDOWN_V2)

    # Schedule trade completion
    asyncio.create_task(send_trade_complete_message(context, chat_id, exit_time))


async def send_trade_complete_message(context, chat_id, exit_time):
    tz = get_timezone_from_offset(context.user_data["timezone_offset"])
    wait_seconds = (exit_time - datetime.now(tz)).total_seconds()

    try:
        if wait_seconds > 0:
            await asyncio.sleep(wait_seconds)
    except asyncio.CancelledError:
        logging.info("Trade completion cancelled before message.")
        context.user_data["signal_running"] = False
        return

    # Skip if not active
    if not context.user_data.get("live_mode_active", False):
        logging.info("Live mode inactive, skipping trade complete message.")
        context.user_data["signal_running"] = False
        return

    # Mark signal finished
    context.user_data["signal_running"] = False

    # ✅ Send only trade completion message (no buttons)
    await context.bot.send_message(
        chat_id=chat_id,
        text="✅ *Trade successfully completed!*\nType /nextsignal to generate a new one.",
        parse_mode="Markdown"
    )


